{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "closecheck",
  "compatibility_date": "2026-04-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist",
    "not_found_handling": "single-page-application"
  },
  "build": {
    "command": "cd frontend && npm install && npm run build"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
