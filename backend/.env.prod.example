# ============================================================================
# CloseCheck Production Environment Configuration
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.prod on the VPS: cp .env.prod.example .env.prod
# 2. Update all placeholders marked with <CHANGE-ME> or <SECRET>
# 3. Set file permissions: chmod 600 .env.prod
# 4. NEVER commit .env.prod to git
# ============================================================================

# ── API Security (NEW — P0 Protections) ────────────────────────────────────
API_KEY_REQUIRED=true
API_KEY=<GENERATE-32-CHAR-RANDOM-SECRET>

# ── Claude Integration ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-<SECRET>
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5

# ── Database (SQLite — local on VPS) ───────────────────────────────────────
DATABASE_URL=sqlite:///./closecheck.db

# ── File Storage (local paths on VPS) ──────────────────────────────────────
UPLOAD_DIR=/var/www/closecheck-backend/uploads
REPORTS_DIR=/var/www/closecheck-backend/reports
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_JOB=20

# ── Demo Mode (DISABLED in Production) ─────────────────────────────────────
DEMO_MODE=false

# ── Email Draft Rate Limiting (NEW — P0 Protections) ───────────────────────
EMAIL_DRAFT_LIMIT_PER_JOB=3
EMAIL_DRAFT_WINDOW_HOURS=24

# ── Upload Rate Limiting (NEW — P0 Protections) ────────────────────────────
UPLOAD_RATE_LIMIT_SECONDS=10

# ── CORS Configuration ─────────────────────────────────────────────────────
# IMPORTANT: Frontend URL must match production static hosting domain
CORS_ALLOW_ORIGINS=["https://app.closecheck.example"]

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Other Configuration ────────────────────────────────────────────────────
ENVIRONMENT=production
